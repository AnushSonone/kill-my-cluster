{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Who is leader?",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 },
          "max": 1,
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "kmc_raft_is_leader",
          "legendFormat": "node {{node_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Raft term",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kmc_raft_term",
          "legendFormat": "node {{node_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Commit index (lockstep = healthy replication)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kmc_raft_commit_index",
          "legendFormat": "node {{node_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Writes / sec (leader applies)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 6, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kmc_kv_writes_total[15s]) and on(instance) (kmc_raft_is_leader == 1))",
          "legendFormat": "writes/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Reads / sec (leader applies)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 6, "x": 18, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kmc_kv_reads_total[15s]) and on(instance) (kmc_raft_is_leader == 1))",
          "legendFormat": "reads/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Host CPU busy %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[30s])))",
          "legendFormat": "cpu busy %",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Host memory used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "total",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["kill-my-cluster", "raft"],
  "templating": { "list": [] },
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Kill My Cluster",
  "uid": "kmc-overview",
  "version": 3
}
