{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Who is leader?",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 },
          "max": 1,
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "kmc_raft_is_leader",
          "legendFormat": "node {{node_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Raft term",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kmc_raft_term",
          "legendFormat": "node {{node_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Commit index (lockstep = healthy replication)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kmc_raft_commit_index",
          "legendFormat": "node {{node_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Propose latency (p50 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(kmc_propose_latency_seconds_bucket[30s])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(kmc_propose_latency_seconds_bucket[30s])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Bank totals (real vs naive)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "real" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "naive" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "kmc_bank_real_total_cents / 100",
          "legendFormat": "real",
          "refId": "A"
        },
        {
          "expr": "kmc_bank_naive_total_cents / 100",
          "legendFormat": "naive",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Applies / sec (cluster throughput)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kmc_kv_applies_total[15s]))",
          "legendFormat": "applies/s",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["kill-my-cluster", "raft"],
  "templating": { "list": [] },
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Kill My Cluster",
  "uid": "kmc-overview",
  "version": 1
}
