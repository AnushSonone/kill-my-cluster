# Loadgen binary for sustained Put/Get traffic.
FROM golang:1.26-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /kmc-loadgen ./cmd/loadgen

FROM gcr.io/distroless/static-debian12
COPY --from=build /kmc-loadgen /kmc-loadgen
ENTRYPOINT ["/kmc-loadgen"]
